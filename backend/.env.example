# =============================================================================
# Blockchain-Enabled Lightweight Security Framework — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# =============================================================================

# ── Application ──
APP_NAME="AgriIoT Security Framework"
APP_VERSION="1.0.0"
DEBUG=true
LOG_LEVEL=INFO

# ── PostgreSQL ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agri_iot_security
POSTGRES_USER=agri_user
POSTGRES_PASSWORD=agri_secure_password_change_me
DATABASE_URL=postgresql+asyncpg://agri_user:agri_secure_password_change_me@localhost:5432/agri_iot_security

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ── JWT Authentication ──
JWT_SECRET_KEY=CHANGE_ME_TO_A_64_CHAR_HEX_STRING_FOR_PRODUCTION
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Key Vault ──
# 32-byte hex string used to derive per-device encryption keys via HKDF.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
VAULT_MASTER_SECRET=CHANGE_ME_TO_A_64_CHAR_HEX_STRING_FOR_PRODUCTION

# ── Security Gateway ──
NONCE_EXPIRY_SECONDS=300
TIMESTAMP_MAX_DRIFT_SECONDS=300

# ── Rate Limiting ──
RATE_LIMIT_DEVICE_MAX=60
RATE_LIMIT_DEVICE_WINDOW=60
RATE_LIMIT_USER_MAX=120
RATE_LIMIT_USER_WINDOW=60
RATE_LIMIT_IP_MAX=30
RATE_LIMIT_IP_WINDOW=60

# ── Feature Drift ──
DRIFT_WINDOW_SIZE=500
DRIFT_PSI_THRESHOLD=0.25
DRIFT_KS_ALPHA=0.05

# ── Trust Score ──
TRUST_SCORE_INITIAL=100.0
TRUST_SCORE_MIN=0.0
TRUST_SCORE_MAX=100.0
TRUST_SUSPEND_THRESHOLD=50.0
TRUST_BLOCK_THRESHOLD=20.0
